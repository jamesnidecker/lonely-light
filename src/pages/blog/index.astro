---
import '../../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog — James Nidecker Tattoo Artist Amsterdam</title>
    <meta name="description" content="Insights on geometric, mandala and blackout tattoos from Amsterdam tattoo artist James Nidecker." />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body style="background:#000; color:#fff; margin:0; padding:0; font-family:'Space Grotesk',sans-serif;">

    <!-- NAV -->
    <nav style="position:fixed; top:0; width:100%; background:#000; border-bottom:1px solid #111; z-index:50; padding:20px 40px; display:flex; align-items:center; justify-content:space-between;">
      <a href="/" style="font-weight:700; letter-spacing:0.2em; text-transform:uppercase; font-size:14px; color:#fff; text-decoration:none;">James Nidecker</a>
      <div style="display:flex; gap:32px; font-size:12px; letter-spacing:0.15em; text-transform:uppercase;">
        <a href="/#work" style="color:#666; text-decoration:none;">Work</a>
        <a href="/#about" style="color:#666; text-decoration:none;">About</a>
        <a href="/#services" style="color:#666; text-decoration:none;">Services</a>
        <a href="/#faq" style="color:#666; text-decoration:none;">FAQ</a>
        <a href="/#contact" style="color:#666; text-decoration:none;">Contact</a>
        <a href="/blog" style="color:#C9A84C; text-decoration:none;">Blog</a>
      </div>
      <a href="https://book.useblink.app/ink-district/james-nidecker?theme=light" target="_blank" style="background:#C9A84C; color:#000; padding:12px 24px; font-weight:700; font-size:11px; letter-spacing:0.15em; text-transform:uppercase; text-decoration:none;">Book Now</a>
    </nav>

    <!-- HEADER -->
    <section style="padding:160px 40px 80px 40px; max-width:900px; margin:0 auto;">
      <p style="color:#C9A84C; font-size:11px; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:16px;">Journal</p>
      <h1 style="font-family:'Archivo',sans-serif; font-weight:900; font-size:clamp(3rem,7vw,6rem); text-transform:uppercase; line-height:0.9; margin:0 0 40px 0;">
        <span style="color:#fff; display:block;">TATTOO</span>
        <span style="color:#C9A84C; display:block;">JOURNAL</span>
      </h1>
      <p style="color:#666; font-size:15px; line-height:1.8; max-width:600px;">Thoughts on geometric design, mandala traditions, blackout work and everything in between.</p>
    </section>

    <!-- BLOG POSTS -->
    <section style="padding:0 40px 120px 40px; max-width:900px; margin:0 auto;">

      <a href="/blog/mandala-tattoo-amsterdam" style="text-decoration:none; display:block; border-top:1px solid #1a1a1a; padding:48px 0; transition:opacity 0.2s;">
        <p style="color:#C9A84C; font-size:11px; letter-spacing:0.2em; text-transform:uppercase; margin:0 0 16px 0;">Mandala · May 2026</p>
        <h2 style="font-family:'Archivo',sans-serif; font-weight:900; font-size:clamp(1.8rem,4vw,3rem); text-transform:uppercase; color:#fff; margin:0 0 16px 0; line-height:1;">The Art and Geometry of Mandala Tattoos</h2>
        <p style="color:#666; font-size:14px; line-height:1.8; margin:0 0 24px 0; max-width:600px;">The history of mandalas, their connection to sacred geometry, what makes a truly exceptional mandala design, and how to care for your new tattoo.</p>
        <span style="color:#C9A84C; font-size:12px; letter-spacing:0.15em; text-transform:uppercase;">Read More →</span>
      </a>

    </section>

    <!-- FOOTER -->
    <footer style="border-top:1px solid #111; padding:40px; text-align:center;">
      <p style="color:#333; font-size:11px; letter-spacing:0.15em; text-transform:uppercase;">© 2026 James Nidecker. All rights reserved.</p>
    </footer>

  </body>
</html>

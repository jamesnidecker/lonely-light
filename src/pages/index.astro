    <script>
    async function loadInstagram() {
      try {
        const res = await fetch('https://feeds.behold.so/R4JBXf79SzJDMUtTid7A');
        const data = await res.json();
        const posts = data.posts.slice(0, 6);
        const grid = document.getElementById('instagram-grid');
        posts.forEach(post => {
          const img = post.sizes?.medium?.mediaUrl || post.thumbnailUrl || post.mediaUrl;
          if (!img) return;
          const a = document.createElement('a');
          a.href = post.permalink;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.style.display = 'block';
          a.style.overflow = 'hidden';
          const i = document.createElement('img');
          i.src = img;
          i.alt = 'James Nidecker tattoo Amsterdam';
          i.loading = 'lazy';
          i.style.width = '100%';
          i.style.aspectRatio = '4/5';
          i.style.objectFit = 'cover';
          i.style.display = 'block';
          i.style.transition = 'transform 0.3s ease';
          a.appendChild(i);
          grid.appendChild(a);
        });
      } catch(e) {
        console.error('Instagram feed error:', e);
      }
    }
    loadInstagram();
    </script>


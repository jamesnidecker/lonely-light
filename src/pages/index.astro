        margin: 0 auto;
      }
      #instagram-grid a {
        display: block;
        overflow: hidden;
      }
      #instagram-grid img {
        width: 100%;
        aspect-ratio: 4/5;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
      }
      #instagram-grid a:hover img {
        transform: scale(1.03);
      }
      @media (max-width: 768px) {
        #instagram-grid { grid-template-columns: repeat(2, 1fr) !important; }
      }
